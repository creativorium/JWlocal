{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jwt/features",
	"title": "JWT Features",
	"category": "jwtrading",
	"icon": "screenoptions",
	"description": "Grid keunggulan / apa yang didapat member.",
	"textdomain": "jwtrading",
	"editorScript": "jwt-blocks-editor",
	"render": "file:./render.php",
	"supports": {
		"align": [ "full" ],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "" },
		"title": { "type": "string", "default": "" },
		"lead": { "type": "string", "default": "" },
		"showTrustBadge": { "type": "boolean", "default": false },
		"center": { "type": "boolean", "default": true },
		"centerCards": { "type": "boolean", "default": false },
		"buttonText": { "type": "string", "default": "" },
		"buttonUrl": { "type": "string", "default": "" }
	}
}
