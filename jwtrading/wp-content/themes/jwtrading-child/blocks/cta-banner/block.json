{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jwt/cta-banner",
	"title": "JWT CTA Banner",
	"category": "jwtrading",
	"icon": "megaphone",
	"description": "Banner CTA horizontal: teks kiri, tombol kanan (mis. WhatsApp).",
	"textdomain": "jwtrading",
	"editorScript": "jwt-blocks-editor",
	"render": "file:./render.php",
	"supports": {
		"align": [ "full" ],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"title": { "type": "string", "default": "" },
		"text": { "type": "string", "default": "" },
		"buttonText": { "type": "string", "default": "" },
		"buttonUrl": { "type": "string", "default": "" }
	}
}
