{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jwt/testimonial-item",
	"title": "JWT Testimonial",
	"category": "jwtrading",
	"icon": "admin-comments",
	"description": "Satu testimoni: kutipan teks atau screenshot.",
	"textdomain": "jwtrading",
	"parent": [ "jwt/testimonials" ],
	"editorScript": "jwt-blocks-editor",
	"render": "file:./render.php",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"quote": { "type": "string", "default": "" },
		"name": { "type": "string", "default": "" },
		"role": { "type": "string", "default": "" },
		"imageId": { "type": "number", "default": 0 },
		"imageUrl": { "type": "string", "default": "" },
		"imageAlt": { "type": "string", "default": "" }
	}
}
