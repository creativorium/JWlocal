{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jwt/contact",
	"title": "JWT Contact",
	"category": "jwtrading",
	"icon": "email-alt",
	"description": "Contact section: WhatsApp/email/location cards + socials on the left, a message form (composes a WhatsApp message) on the right.",
	"textdomain": "jwtrading",
	"editorScript": "jwt-blocks-editor",
	"render": "file:./render.php",
	"supports": { "align": [ "full" ], "html": false, "anchor": true },
	"attributes": {
		"eyebrow": { "type": "string", "default": "" },
		"title": { "type": "string", "default": "" },
		"lead": { "type": "string", "default": "" },
		"center": { "type": "boolean", "default": true },
		"waNumber": { "type": "string", "default": "" },
		"waDisplay": { "type": "string", "default": "" },
		"email": { "type": "string", "default": "" },
		"emailNote": { "type": "string", "default": "" },
		"location": { "type": "string", "default": "" },
		"locationNote": { "type": "string", "default": "" },
		"formTitle": { "type": "string", "default": "" },
		"formNote": { "type": "string", "default": "" },
		"formFootnote": { "type": "string", "default": "" }
	}
}
