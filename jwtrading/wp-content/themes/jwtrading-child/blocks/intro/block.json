{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jwt/intro",
	"title": "JWT Intro",
	"category": "jwtrading",
	"icon": "text-page",
	"description": "Centered intro: eyebrow, heading, body paragraphs, and a CTA button (no box).",
	"textdomain": "jwtrading",
	"editorScript": "jwt-blocks-editor",
	"render": "file:./render.php",
	"supports": {
		"align": [ "full" ],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "" },
		"title": { "type": "string", "default": "" },
		"body": { "type": "string", "default": "" },
		"buttonText": { "type": "string", "default": "" },
		"buttonUrl": { "type": "string", "default": "" }
	}
}
